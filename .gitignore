# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (kita pakai go mod, jadi vendor biasanya tidak di-push)
# vendor/

# Go workspace file
go.work
go.work.sum

# IDE specific files
.idea/
.vscode/
*.swp
*.swo

# OS specific files
.DS_Store
Thumbs.db

# Project specific
# Jika kamu ingin orang lain men-generate sendiri protobuf-nya, 
# kamu bisa ignore file .pb.go, tapi biasanya untuk kemudahan, 
# file .pb.go tetap di-push.
proto/*.pb.go
proto/*_grpc.pb.go

# Environment variables (SANGAT PENTING jika nanti ada file .env)
*.env